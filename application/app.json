{
  "expo": {
    "name": "Saksham Homoeopathy",
    "slug": "saksham-homoeopathy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arniparth.sakshamhomeopathy",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.arniparth.sakshamhomoeopathy",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAppCheck",
              "RNFBAuth",
              "RNFBFirestore",
              "RNFBStorage"
            ]
          },
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ],
      "@react-native-firebase/auth",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/image.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Saksham Homoeopathy uses your photo library so you can set a profile picture for your clinic account."
        }
      ],
      "expo-video",
      "react-native-compressor"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e8e0d64e-2cac-4c08-b093-e78c63236af0"
      },
      "legal": {
        "privacyPolicyUrl": "https://shashank26.github.io/saksham-homoeopathy-v2/",
        "termsUrl": "https://shashank26.github.io/saksham-homoeopathy-v2/terms",
        "feedbackUrl": "mailto:arniparth@gmail.com?subject=Saksham%20Homoeopathy%20App%20Feedback",
        "supportEmail": "arniparth@gmail.com"
      }
    }
  }
}
