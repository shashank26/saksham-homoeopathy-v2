{
  "expo": {
    "name": "Saksham Homoeopathy",
    "slug": "saksham-homoeopathy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arniparth.sakshamhomeopathy",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.arniparth.sakshamhomoeopathy",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "@react-native-firebase/auth",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/image.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Saksham Homoeopathy uses your photo library so you can set a profile picture for your clinic account."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e8e0d64e-2cac-4c08-b093-e78c63236af0"
      },
      "legal": {
        "privacyPolicyUrl": "https://sakshamhomoeopathy.com/privacy-policy",
        "termsUrl": "https://sakshamhomoeopathy.com/terms",
        "feedbackUrl": "mailto:support@sakshamhomoeopathy.com?subject=Saksham%20Homoeopathy%20App%20Feedback",
        "supportEmail": "support@sakshamhomoeopathy.com"
      }
    }
  }
}
